# Environment variables untuk Flask REST API

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=booking123-secret-key-change-in-production

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=booking_lapangan

# JWT Configuration
JWT_SECRET=jwt-secret-key-change-in-production

# CORS Configuration (comma separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,https://yourapp.com
